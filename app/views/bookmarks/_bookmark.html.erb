<!-- app/views/bookmarks/_bookmark.html.erb -->
<div class="col-12 col-sm-6 mb-4">
  <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden">
    <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>" style="height: 250px; object-fit: cover;">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start">
        <h5 class="card-title fw-bold mb-0"><%= bookmark.movie.title %></h5>
        <span class="text-warning fw-bold"><%= bookmark.movie.rating %> <i class="fas fa-star"></i></span>
      </div>
      <p class="card-text text-muted small mt-2"><%= truncate(bookmark.movie.overview, length: 100) %></p>

      <div class="d-flex align-items-center justify-content-between border-top pt-3 mt-auto">
        <small class="text-secondary italic">
          <i class="fas fa-comment-dots me-1"></i> "<%= bookmark.comment %>"
        </small>
        <%= link_to bookmark_path(bookmark),
                    data: { turbo_method: :delete, turbo_confirm: "Remove #{bookmark.movie.title}?" },
                    class: "btn btn-outline-danger btn-sm rounded-pill" do %>
          <i class="fas fa-trash-alt"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>
