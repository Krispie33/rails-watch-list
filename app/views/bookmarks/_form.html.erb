<!-- app/views/bookmarks/_form.html.erb -->
<div class="p-4 bg-light rounded-4 shadow-sm">
  <h5 class="fw-bold mb-3">Add a movie</h5>
  <%= simple_form_for [list, bookmark] do |f| %>
    <%= f.error_notification %>

    <%= f.association :movie,
                      collection: Movie.order(:title),
                      prompt: "Choose a movie...",
                      input_html: { class: "form-select rounded-3" } %>

    <%= f.input :comment,
                placeholder: "Why this movie? (min. 6 chars)",
                input_html: { class: "rounded-3" } %>

    <%= f.submit "Add to list", class: "btn btn-primary w-100 mt-3 rounded-pill fw-bold" %>
  <% end %>
</div>
