<div class="banner mb-5" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://images.unsplash.com);">
  <div class="container text-center py-5">
    <h1 class="display-3 text-white fw-bold">My Movie Playlists</h1>
    <p class="lead text-white">Save your favorite movies in custom lists.</p>
    <%= link_to "Create a new list", new_list_path, class: "btn btn-primary btn-lg rounded-pill px-4 mt-3" %>
  </div>
</div>

<div class="container pb-5">
  <div class="row g-4">
    <% @lists.each do |list| %>
      <div class="col-12 col-md-6 col-lg-4">
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden list-card text-white text-center"
               style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://source.unsplash.com<%= list.id %>');">
            <div class="card-body d-flex align-items-center justify-content-center py-5">
              <h2 class="card-title fw-bold text-shadow"><%= list.name %></h2>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
